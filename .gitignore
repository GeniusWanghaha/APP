# =========================
# APP workspace ignore rules
# =========================

# Large datasets (local only)
project_root/datasets/

# Python virtual env/cache (dataset validation subproject)
project_root/env/
project_root/.venv/
project_root/__pycache__/
project_root/**/*.pyc
project_root/.ipynb_checkpoints/

# Android build/cache artifacts
android_project/.gradle/
android_project/app/build/
android_project/.idea/caches/
android_project/.idea/libraries/
android_project/.idea/workspace.xml

# Doc extraction intermediates
android_project/docs/_docx_extract_v11_ui/
android_project/docs/word_v11_extracted.txt

# OS artifacts
.DS_Store
Thumbs.db
